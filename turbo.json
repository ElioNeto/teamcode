{
  "$schema": "https://v2-8-13.turborepo.dev/schema.json",
  "globalEnv": ["CI", "TEAMCODE_DISABLE_SHARE"],
  "globalPassThroughEnv": ["CI", "TEAMCODE_DISABLE_SHARE"],
  "tasks": {
    "typecheck": {},
    "build": {
      "dependsOn": [],
      "outputs": ["dist/**"]
    },
"teamcode#test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "teamcode#test:ci": {
      "dependsOn": ["^build"],
      "outputs": [".artifacts/unit/junit.xml"],
      "passThroughEnv": ["*"]
    },
    "@teamcode-ai/app#test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@teamcode-ai/app#test:ci": {
      "dependsOn": ["^build"],
      "outputs": [".artifacts/unit/junit.xml"],
      "passThroughEnv": ["*"]
    },
    "@teamcode-ai/ui#test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@teamcode-ai/ui#test:ci": {
      "dependsOn": ["^build"],
      "outputs": [".artifacts/unit/junit.xml"],
      "passThroughEnv": ["*"]
    }
  }
}
